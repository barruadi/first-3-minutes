# Simple 6 m x 4 m evacuation demonstration room (units: meters)
# Coordinate convention: X right, Y up, Z forward. Doorway is in the +Z wall.
o DemoEvacuationRoom

# floor
v -3.0 0.0 -2.0
v  3.0 0.0 -2.0
v  3.0 0.0  2.0
v -3.0 0.0  2.0
f 1 2 3 4

# back wall
v -3.0 0.0 -2.0
v -3.0 2.8 -2.0
v  3.0 2.8 -2.0
v  3.0 0.0 -2.0
f 5 6 7 8

# left wall
v -3.0 0.0 -2.0
v -3.0 0.0  2.0
v -3.0 2.8  2.0
v -3.0 2.8 -2.0
f 9 10 11 12

# right wall
v 3.0 0.0 -2.0
v 3.0 2.8 -2.0
v 3.0 2.8  2.0
v 3.0 0.0  2.0
f 13 14 15 16

# front wall, split around a 1.2 m doorway centered at x=0.8
v -3.0 0.0 2.0
v  0.2 0.0 2.0
v  0.2 2.8 2.0
v -3.0 2.8 2.0
f 17 18 19 20
v 1.4 0.0 2.0
v 3.0 0.0 2.0
v 3.0 2.8 2.0
v 1.4 2.8 2.0
f 21 22 23 24
v 0.2 2.1 2.0
v 1.4 2.1 2.0
v 1.4 2.8 2.0
v 0.2 2.8 2.0
f 25 26 27 28

# sturdy desk / safe zone
v -2.4 0.72 -1.3
v -1.2 0.72 -1.3
v -1.2 0.72 -0.3
v -2.4 0.72 -0.3
v -2.4 0.82 -1.3
v -1.2 0.82 -1.3
v -1.2 0.82 -0.3
v -2.4 0.82 -0.3
f 29 30 31 32
f 33 36 35 34
f 29 33 34 30
f 30 34 35 31
f 31 35 36 32
f 32 36 33 29

# tall cabinet / hazard zone
v -0.45 0.0 -1.65
v  0.45 0.0 -1.65
v  0.45 0.0 -0.75
v -0.45 0.0 -0.75
v -0.45 2.2 -1.65
v  0.45 2.2 -1.65
v  0.45 2.2 -0.75
v -0.45 2.2 -0.75
f 37 38 39 40
f 41 44 43 42
f 37 41 42 38
f 38 42 43 39
f 39 43 44 40
f 40 44 41 37
