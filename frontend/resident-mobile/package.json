{
  "name": "@3minutes/resident-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios:dev": "eas build --platform ios --profile development",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@3minutes/contracts": "*",
    "@3minutes/design-tokens": "*",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.28",
    "expo-av": "~14.0.7",
    "expo-camera": "~15.0.16",
    "expo-dev-client": "~4.0.26",
    "expo-file-system": "~17.0.1",
    "expo-image-manipulator": "~12.0.5",
    "expo-secure-store": "~13.0.2",
    "expo-sensors": "~13.0.9",
    "expo-speech": "~12.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-video-thumbnails": "~8.0.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.9",
    "react-native-screens": "3.34.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^12.6.1",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "@types/react-test-renderer": "18.0.7",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "jest": "^29.2.1",
    "jest-expo": "~51.0.3",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@3minutes/.*)"
    ]
  }
}
